<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mitt CV</title>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body>
    <header>
        <h1>Mitt CV</h1>

        <nav>
            <ul>
                <li><a href="/">Mina kurser</a></li>
                <li><a href="/addCourse">Lägg till kurs</a></li>
                <li><a href="/about">Om sidan</a></li>
            </ul>
        </nav>
    </header>

    <section>
        <h2>Dina kurser</h2>
        <ul id="yourCourses">
            <% courses.forEach(course => { %>
                <li>
                    <strong><%= course.course_name %></strong>
                    (<%= course.course_code %>) - <%= course.progression %>
                    <a href="<%= course.syllabus %>" target="_blank">Kursplan</a>

                    <form action="/delete/<%= course.id %>" method="POST" style="display:inline;">
                        <button type="submit">Ta bort kurs</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    </section>
</body>
</html>